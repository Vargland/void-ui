{
  "name": "@open-void-ui/mcp-server",
  "version": "0.1.0",
  "description": "MCP server — exposes void-ui component library as context for Claude and Cursor",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "void-ui-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
